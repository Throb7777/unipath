<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_page"
    android:orientation="vertical"
    tools:context=".ui.SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp">

        <ImageButton
            android:id="@+id/topBarBackButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back_24"
            android:tint="@color/link_blue"
            tools:contentDescription="Back" />

        <TextView
            android:id="@+id/topBarTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/text_primary"
            tools:text="Relay Settings" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface_stroke" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/serviceSectionTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="@color/text_primary"
                    tools:text="Forwarding Service" />

                <TextView
                    android:id="@+id/serviceSectionHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Set the service address, test the connection, and choose a mode." />

                <TextView
                    android:id="@+id/connectionTypeLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Connection Type" />

                <TextView
                    android:id="@+id/connectionTypeHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Choose the kind of address the Android app should use to reach your relay." />

                <RadioGroup
                    android:id="@+id/connectionTypeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RadioButton
                        android:id="@+id/connectionEmulatorRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:text="Android Emulator" />

                    <RadioButton
                        android:id="@+id/connectionLocalRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        tools:text="Local Network" />

                    <RadioButton
                        android:id="@+id/connectionPrivateRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        tools:text="Private Network" />
                </RadioGroup>

                <TextView
                    android:id="@+id/serviceLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Relay Base URL" />

                <EditText
                    android:id="@+id/relayBaseUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel"
                    android:hint="@string/settings_service_placeholder"
                    android:inputType="textUri"
                    android:minHeight="56dp"
                    android:padding="18dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    tools:text="http://10.0.2.2:8080" />

                <TextView
                    android:id="@+id/serviceHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Use the relay base URL only." />

                <TextView
                    android:id="@+id/serviceProfileNameLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Saved Service Name" />

                <EditText
                    android:id="@+id/serviceProfileNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel"
                    android:hint="Home Relay"
                    android:inputType="textCapWords"
                    android:minHeight="56dp"
                    android:padding="18dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    tools:text="Home Relay" />

                <TextView
                    android:id="@+id/currentSavedProfileText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Saved on this phone as Home Relay." />

                <TextView
                    android:id="@+id/serviceAuthLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Relay Auth Token" />

                <Button
                    android:id="@+id/showAuthButton"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="8dp"
                    android:textAllCaps="false"
                    android:textColor="@color/link_blue"
                    tools:text="Use auth token (optional)" />

                <LinearLayout
                    android:id="@+id/serviceAuthContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/relayAuthInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_panel"
                        android:hint="@string/settings_service_auth_placeholder"
                        android:inputType="textPassword"
                        android:minHeight="56dp"
                        android:padding="18dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        tools:text="ui-test-token" />

                    <TextView
                        android:id="@+id/serviceAuthHintText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/text_secondary"
                        tools:text="Optional on local networks, but recommended for private or public relay access." />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/statusLabelText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/text_primary"
                        tools:text="Connection &amp; Sync" />

                    <Button
                        android:id="@+id/testConnectionButton"
                        style="?attr/borderlessButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:paddingHorizontal="8dp"
                        android:textAllCaps="false"
                        android:textColor="@color/link_blue"
                        tools:text="Test" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusValueText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel"
                    android:minHeight="72dp"
                    android:padding="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="@color/text_primary"
                    tools:text="Ready." />

                <TextView
                    android:id="@+id/modeLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Available Modes" />

                <TextView
                    android:id="@+id/modeHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Fetch the mode list first." />

                <TextView
                    android:id="@+id/modeEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel"
                    android:padding="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="@color/text_secondary"
                    tools:text="No modes yet." />

                <RadioGroup
                    android:id="@+id/modeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/modeDescriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel"
                    android:padding="16dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"
                    tools:text="Selected mode description appears here." />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/appSectionTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="@color/text_primary"
                    tools:text="App Settings" />

                <TextView
                    android:id="@+id/appSectionHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Adjust app-only preferences here." />

                <TextView
                    android:id="@+id/languageLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="App Language" />

                <TextView
                    android:id="@+id/languageHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Choose the app language." />

                <RadioGroup
                    android:id="@+id/languageRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RadioButton
                        android:id="@+id/languageEnglishRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/language_english" />

                    <RadioButton
                        android:id="@+id/languageChineseRadio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/language_simplified_chinese" />
                </RadioGroup>

                <TextView
                    android:id="@+id/recentTasksLimitLabelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/text_primary"
                    tools:text="Recent Tasks" />

                <TextView
                    android:id="@+id/recentTasksLimitHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/text_secondary"
                    tools:text="Choose how many recent tasks the home screen should show." />

                <Button
                    android:id="@+id/recentTasksLimitButton"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="8dp"
                    android:textAllCaps="false"
                    android:textColor="@color/link_blue"
                    tools:text="Show 20 tasks" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/resetDefaultsButton"
                    style="?attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:paddingHorizontal="8dp"
                    android:textAllCaps="false"
                    android:textColor="@color/link_blue"
                    tools:text="Use defaults" />

                <Button
                    android:id="@+id/saveSettingsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    tools:text="Save" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>

